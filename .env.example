# Copy the public port-8080 endpoint from your TopDuka ScaleApp in ScaleNodes.
TOPDUKA_API_URL=https://your-app-port-8080.go.scalenodes.app

# Create a public API key in TopDuka. This remains server-only.
TOPDUKA_API_KEY=ak_your_store_api_key

# Optional: route customer conversations to one configured TopDuka agent.
TOPDUKA_AGENT_ID=
